{
  "name": "@prooflink/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "ProofLink MCP compliance server — sanctions screening, KYA, travel rule, and compliant payments for AI agents",
  "license": "MIT",
  "bin": {
    "prooflink-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@prooflink/core": "workspace:*",
    "@prooflink/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
